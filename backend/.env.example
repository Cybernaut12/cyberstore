PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/cyberstore?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_secret
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

PAYSTACK_SECRET_KEY=your_paystack_secret
PAYSTACK_PUBLIC_KEY=your_paystack_public
PAYSTACK_CALLBACK_URL=http://localhost:3000/payment-success

# Brevo SMTP (recommended)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=CyberStore <no-reply@yourdomain.com>
EMAIL_TIMEOUT_MS=8000

# Optional aliases (same values as above, if you prefer BREVO_* naming)
# BREVO_SMTP_LOGIN=
# BREVO_SMTP_KEY=
# BREVO_EMAIL_FROM=CyberStore <no-reply@yourdomain.com>

GOOGLE_CLIENT_ID=your_google_client_id
